{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Server",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/index.js",
      "skipFiles": [
        "<node_internals>/**"
      ]
    },

    {
      "type": "pwa-chrome",  
      "request": "launch",
      "name": "Launch Chrome", 
      "url": "http://localhost:3000", 
      "webRoot": "${workspaceFolder}/public"
    }
  ]
}